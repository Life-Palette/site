---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="拾色 - Life Palette">
  <div class="page">
    <div class="bg-text" aria-hidden="true">Life Palette</div>
    <main>
      <div class="title-wrap">
        <h1>拾色</h1>
        <div class="rainbow-glow"></div>
      </div>
      <p class="subtitle">Life Palette</p>
      <p class="tagline">以色彩为笔，记录生活的每一帧</p>
      <div class="features">
        <span>色彩提取</span>
        <span class="dot"></span>
        <span>图片处理</span>
        <span class="dot"></span>
        <span>本地运行</span>
      </div>
      <a href="#" class="download">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        App Store 下载
      </a>
    </main>

    <footer>
      <nav>
        <a href={`${import.meta.env.BASE_URL}user-protocol`}>用户协议</a>
        <a href={`${import.meta.env.BASE_URL}privacy-policy`}>隐私政策</a>
        <a href={`${import.meta.env.BASE_URL}support`}>支持</a>
      </nav>
      <p class="copyright">© {new Date().getFullYear()} Life Palette. All rights reserved.</p>
    </footer>
  </div>
</BaseLayout>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }

  .bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Playfair Display', serif;
    font-size: clamp(6rem, 18vw, 16rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    background: linear-gradient(
      135deg,
      rgba(92, 61, 46, 0.04) 0%,
      rgba(255, 180, 150, 0.05) 50%,
      rgba(150, 200, 255, 0.04) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
  }

  main {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .title-wrap {
    position: relative;
    display: inline-block;
  }

  h1 {
    font-family: 'Noto Serif SC', serif;
    font-size: 4.5rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #5C3D2E;
    position: relative;
    z-index: 1;
  }

  .rainbow-glow {
    position: absolute;
    top: -15%;
    right: -35%;
    width: 110px;
    height: 150px;
    background: linear-gradient(
      140deg,
      rgba(255, 170, 170, 0.5) 0%,
      rgba(255, 200, 140, 0.45) 20%,
      rgba(255, 230, 150, 0.4) 40%,
      rgba(170, 230, 190, 0.35) 60%,
      rgba(150, 200, 255, 0.4) 80%,
      rgba(200, 170, 255, 0.35) 100%
    );
    border-radius: 40% 60% 50% 50%;
    filter: blur(16px);
    z-index: 0;
    pointer-events: none;
    transform: rotate(-20deg);
  }

  .subtitle {
    margin-top: 0.5rem;
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    color: #aaa;
    letter-spacing: 0.2em;
    font-weight: 700;
    font-style: italic;
  }

  .tagline {
    margin-top: 1.5rem;
    font-size: 1.15rem;
    color: #555;
  }

  .features {
    margin-top: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: #999;
  }

  .features .dot {
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #ccc;
  }

  .download {
    margin-top: 2.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    background: #5C3D2E;
    border: none;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 500;
    color: #fff;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }

  .download:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  footer {
    padding: 2rem 0;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  footer nav {
    display: flex;
    gap: 2rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  footer nav a {
    font-size: 0.8rem;
    color: #999;
    text-decoration: none;
  }

  footer nav a:hover {
    color: #5C3D2E;
  }

  .copyright {
    font-size: 0.75rem;
    color: #ccc;
  }
</style>
